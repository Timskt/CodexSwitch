<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CodexSwitch.ViewModels"
        xmlns:ui="using:CodexSwitch.Controls"
        x:Class="CodexSwitch.Views.MiniStatusDetailsWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="380"
        Height="276"
        MinWidth="340"
        MaxWidth="380"
        CanResize="False"
        ShowInTaskbar="False"
        WindowDecorations="None"
        WindowStartupLocation="Manual"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        TransparencyBackgroundFallback="Transparent"
        Topmost="True">
    <Border CornerRadius="{StaticResource CsRadiusMd}"
            ClipToBounds="True"
            BorderBrush="{StaticResource CsBorderBrush}"
            BorderThickness="1"
            Background="{StaticResource CsPopoverBrush}"
            Padding="12">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="12">
                <Grid ColumnDefinitions="Auto,*"
                      ColumnSpacing="10">
                    <Border Width="32"
                            Height="32"
                            CornerRadius="{StaticResource CsRadiusMd}"
                            Background="{StaticResource CsMutedBrush}"
                            BorderBrush="{StaticResource CsBorderBrush}"
                            BorderThickness="1">
                        <ui:CsImageIcon Path="{Binding MiniStatusProviderIconPath}"
                                        Width="23"
                                        Height="23"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1"
                                Spacing="1"
                                VerticalAlignment="Center">
                        <TextBlock Text="{Binding MiniStatusProviderName}"
                                   Foreground="{StaticResource CsForegroundBrush}"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="Live usage"
                                   Foreground="{StaticResource CsMutedForegroundBrush}"
                                   FontSize="11"/>
                    </StackPanel>
                </Grid>

                <ItemsControl ItemsSource="{Binding MiniStatusMetricCards}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="1"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:MiniStatusMetricCardItem">
                            <Border Margin="0,0,6,0"
                                    Padding="10,8"
                                    CornerRadius="{StaticResource CsRadiusMd}"
                                    Background="{StaticResource CsCardBrush}"
                                    BorderBrush="{StaticResource CsBorderBrush}"
                                    BorderThickness="1">
                                <Grid RowDefinitions="Auto,Auto,Auto"
                                      RowSpacing="4">
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="5">
                                        <TextBlock Text="{Binding Label}"
                                                   Foreground="{StaticResource CsMutedForegroundBrush}"
                                                   FontSize="12"
                                                   IsVisible="{Binding ShowsTextLabel}"/>
                                        <ui:CsActivityArrow Glyph="{Binding ArrowGlyph}"
                                                            Direction="{Binding ArrowDirection}"
                                                            IsActive="{Binding IsActive}"
                                                            Foreground="{StaticResource CsMutedForegroundBrush}"
                                                            ActiveForeground="{Binding ArrowActiveForeground}"
                                                            FontSize="12"
                                                            Width="13"
                                                            Height="15"
                                                            IsVisible="{Binding ShowsArrow}"/>
                                    </StackPanel>
                                    <ui:CsRollingNumber Grid.Row="1"
                                                        Value="{Binding NumericValue}"
                                                        UseCompactFormat="{Binding UseCompactValueFormat}"
                                                        Foreground="{StaticResource CsForegroundBrush}"
                                                        FontSize="20"
                                                        FontWeight="SemiBold"
                                                        MinWidth="24"
                                                        MaxWidth="106"/>
                                    <TextBlock Grid.Row="2"
                                               Text="{Binding Caption}"
                                               Foreground="{StaticResource CsMutedForegroundBrush}"
                                               FontSize="10"
                                               TextTrimming="CharacterEllipsis"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Border CornerRadius="{StaticResource CsRadiusMd}"
                        Background="{StaticResource CsCardBrush}"
                        BorderBrush="{StaticResource CsBorderBrush}"
                        BorderThickness="1"
                        Padding="10,8"
                        IsVisible="{Binding MiniStatusHasQuotaRow}">
                    <ItemsControl ItemsSource="{Binding MiniStatusQuotaCards}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:MiniStatusQuotaCardItem">
                                <Grid RowDefinitions="Auto,Auto"
                                      ColumnDefinitions="Auto,*"
                                      ColumnSpacing="12"
                                      RowSpacing="7"
                                      Margin="0,4">
                                    <TextBlock Text="{Binding Title}"
                                               Foreground="{StaticResource CsMutedForegroundBrush}"
                                               FontSize="12"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                    <StackPanel Grid.Column="1"
                                                Orientation="Horizontal"
                                                HorizontalAlignment="Right"
                                                Spacing="5">
                                        <TextBlock Text="{Binding Remaining}"
                                                   Foreground="{StaticResource CsForegroundBrush}"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxWidth="96"/>
                                        <TextBlock Text="{Binding Total}"
                                                   Foreground="{StaticResource CsMutedForegroundBrush}"
                                                   FontSize="11"
                                                   VerticalAlignment="Bottom"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxWidth="120"/>
                                    </StackPanel>
                                    <ProgressBar Grid.Row="1"
                                                 Grid.ColumnSpan="2"
                                                 Minimum="0"
                                                 Maximum="100"
                                                 Value="{Binding Percent}"
                                                 Height="6"
                                                 Foreground="{StaticResource CsSidebarPrimaryBrush}"
                                                 Background="{StaticResource CsMutedBrush}"/>
                                    <TextBlock Grid.Row="1"
                                               Grid.Column="1"
                                               Text="{Binding PercentText}"
                                               Foreground="{StaticResource CsForegroundBrush}"
                                               FontSize="10"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               Margin="0,0,2,0"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>

                <Border CornerRadius="{StaticResource CsRadiusMd}"
                        Background="{StaticResource CsCardBrush}"
                        BorderBrush="{StaticResource CsBorderBrush}"
                        BorderThickness="1"
                        Padding="10,7"
                        IsVisible="{Binding MiniStatusHasDetails}">
                    <ItemsControl ItemsSource="{Binding MiniStatusDetails}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:MiniStatusDetailItem">
                                <Grid ColumnDefinitions="76,*"
                                      ColumnSpacing="10"
                                      Margin="0,3">
                                    <TextBlock Text="{Binding Label}"
                                               FontSize="12"
                                               LineHeight="18"
                                               Foreground="{StaticResource CsMutedForegroundBrush}"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Value}"
                                               FontSize="12"
                                               LineHeight="18"
                                               Foreground="{StaticResource CsForegroundBrush}"
                                               TextAlignment="Right"
                                               TextWrapping="Wrap"
                                               MaxHeight="36"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Border>
</Window>
