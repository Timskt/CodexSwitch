<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CodexSwitch.ViewModels"
             xmlns:ui="using:CodexSwitch.Controls"
             xmlns:i18n="using:CodexSwitch.I18n"
             xmlns:lucide="using:Lucide.Avalonia"
             x:Class="CodexSwitch.Views.Pages.ModelsPage"
             x:Name="Root"
             x:DataType="vm:MainWindowViewModel">
    <Grid Margin="24,12,24,24"
          RowDefinitions="Auto,Auto,*"
          RowSpacing="18"
          ClipToBounds="True">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Spacing="4">
                    <ui:CsText Text="{i18n:Tr models.title}" Classes="title"/>
                    <ui:CsText Text="{i18n:Tr models.description}"
                               Classes="muted"/>
                </StackPanel>
                <ui:CsButton Grid.Column="1"
                             Classes="compact"
                             Command="{Binding AddPricingModelCommand}"
                             VerticalAlignment="Top">
                    <StackPanel Orientation="Horizontal" Spacing="7">
                        <lucide:LucideIcon Kind="Plus" Size="14" StrokeWidth="2"/>
                        <TextBlock Text="{i18n:Tr models.add}"/>
                    </StackPanel>
                </ui:CsButton>
            </Grid>

            <ui:CsPanel Grid.Row="1" Padding="16">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <Border Width="34"
                                Height="34"
                                CornerRadius="10"
                                Background="#1734D399"
                                BorderBrush="#2634D399"
                                BorderThickness="1">
                            <lucide:LucideIcon Kind="BookOpenCheck"
                                               Size="17"
                                               StrokeWidth="2"
                                               Foreground="#34D399"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Spacing="2">
                            <ui:CsText Text="{i18n:Tr models.catalog.title}" FontWeight="SemiBold"/>
                            <ui:CsText Text="{i18n:Tr models.catalog.description}" Classes="muted"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <ui:CsBadge>
                            <ui:CsText Text="{Binding PricingUnitText}" Classes="muted"/>
                        </ui:CsBadge>
                        <ui:CsBadge>
                            <ui:CsText Text="{Binding ModelCatalogCountText}" Classes="muted"/>
                        </ui:CsBadge>
                    </StackPanel>
                </Grid>
            </ui:CsPanel>

        <ui:CsPanel Grid.Row="2" Padding="0">
            <Grid RowDefinitions="*">
                <ScrollViewer Grid.Row="0"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                    <ui:CsTable MinWidth="860">
                        <Grid RowDefinitions="Auto,*">
                            <ui:CsTableHeader>
                                <Grid ColumnDefinitions="1.45*,1.7*,0.7*,0.78*,0.86*,0.7*,0.62*,112"
                                      ColumnSpacing="8">
                                    <ui:CsTableHead Content="{i18n:Tr usage.table.model}"/>
                                    <ui:CsTableHead Grid.Column="1" Content="{i18n:Tr settings.tab.route}"/>
                                    <ui:CsTableHead Grid.Column="2" Content="{i18n:Tr models.price.input}"/>
                                    <ui:CsTableHead Grid.Column="3" Content="{i18n:Tr models.price.cacheRead}"/>
                                    <ui:CsTableHead Grid.Column="4" Content="{i18n:Tr models.price.cacheCreate}"/>
                                    <ui:CsTableHead Grid.Column="5" Content="{i18n:Tr models.price.output}"/>
                                    <ui:CsTableHead Grid.Column="6" Content="{i18n:Tr models.price.fast}"/>
                                    <ui:CsTableHead Grid.Column="7" Content=""/>
                                </Grid>
                            </ui:CsTableHeader>

                            <ListBox Grid.Row="1"
                                     ItemsSource="{Binding ModelCatalogRows}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Padding="0"
                                     SelectionMode="Single"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListBox.Styles>
                                    <Style Selector="ListBoxItem">
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Focusable" Value="False"/>
                                        <Setter Property="Template">
                                            <ControlTemplate>
                                                <ContentPresenter Content="{TemplateBinding Content}"
                                                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                                                  HorizontalAlignment="Stretch"/>
                                            </ControlTemplate>
                                        </Setter>
                                    </Style>
                                </ListBox.Styles>
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <VirtualizingStackPanel/>
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ModelCatalogItem">
                                        <ui:CsTableRow Classes="model-row">
                                            <Grid ColumnDefinitions="1.45*,1.7*,0.7*,0.78*,0.86*,0.7*,0.62*,112"
                                                  ColumnSpacing="8"
                                                  MinHeight="82">
                                                <ui:CsTableCell>
                                                    <Grid ColumnDefinitions="Auto,*"
                                                          ColumnSpacing="10">
                                                        <Border Classes="model-icon-shell"
                                                                VerticalAlignment="Center">
                                                            <ui:CsImageIcon Path="{Binding IconPath}"
                                                                            Width="21"
                                                                            Height="21"
                                                                            HorizontalAlignment="Center"
                                                                            VerticalAlignment="Center"/>
                                                        </Border>
                                                        <StackPanel Grid.Column="1"
                                                                    Spacing="4"
                                                                    VerticalAlignment="Center"
                                                                    MinWidth="0">
                                                            <Grid ColumnDefinitions="*,Auto"
                                                                  ColumnSpacing="8">
                                                                <ui:CsText Text="{Binding DisplayName}"
                                                                           FontWeight="SemiBold"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           MinWidth="0"/>
                                                                <ui:CsBadge Grid.Column="1"
                                                                            Classes="model-provider-badge"
                                                                            Padding="7,2">
                                                                    <ui:CsText Text="{Binding IconSlug}"
                                                                               Classes="muted"
                                                                               FontSize="11"/>
                                                                </ui:CsBadge>
                                                            </Grid>
                                                            <ui:CsText Text="{Binding Id}"
                                                                       Classes="muted"
                                                                       FontSize="12"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       ToolTip.Tip="{Binding Id}"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </ui:CsTableCell>

                                                <ui:CsTableCell Grid.Column="1">
                                                    <StackPanel Spacing="3"
                                                                VerticalAlignment="Center"
                                                                MinWidth="0">
                                                        <ui:CsText Text="{Binding AliasesText}"
                                                                   Classes="muted"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   ToolTip.Tip="{Binding AliasesText}"/>
                                                        <ui:CsText Text="{Binding ProvidersText}"
                                                                   Classes="muted"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   ToolTip.Tip="{Binding ProvidersText}"/>
                                                    </StackPanel>
                                                </ui:CsTableCell>

                                                <ui:CsTableCell Grid.Column="2">
                                                    <ui:CsPriceChip>
                                                        <Grid RowDefinitions="Auto,Auto" RowSpacing="2">
                                                            <ui:CsText Text="{Binding InputPriceText}"
                                                                       FontWeight="SemiBold"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                            <ui:CsText Grid.Row="1"
                                                                       Text="{Binding InputTierText}"
                                                                       Classes="muted"
                                                                       FontSize="11"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                        </Grid>
                                                    </ui:CsPriceChip>
                                                </ui:CsTableCell>

                                                <ui:CsTableCell Grid.Column="3">
                                                    <ui:CsPriceChip>
                                                        <Grid RowDefinitions="Auto,Auto" RowSpacing="2">
                                                            <ui:CsText Text="{Binding CachedInputPriceText}"
                                                                       FontWeight="SemiBold"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                            <ui:CsText Grid.Row="1"
                                                                       Text="{i18n:Tr models.price.cacheHit}"
                                                                       Classes="muted"
                                                                       FontSize="11"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                        </Grid>
                                                    </ui:CsPriceChip>
                                                </ui:CsTableCell>

                                                <ui:CsTableCell Grid.Column="4">
                                                    <ui:CsPriceChip>
                                                        <Grid RowDefinitions="Auto,Auto" RowSpacing="2">
                                                            <ui:CsText Text="{Binding CacheCreationInputPriceText}"
                                                                       FontWeight="SemiBold"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                            <ui:CsText Grid.Row="1"
                                                                       Text="{i18n:Tr models.price.claudeWrite}"
                                                                       Classes="muted"
                                                                       FontSize="11"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                        </Grid>
                                                    </ui:CsPriceChip>
                                                </ui:CsTableCell>

                                                <ui:CsTableCell Grid.Column="5">
                                                    <ui:CsPriceChip>
                                                        <Grid RowDefinitions="Auto,Auto" RowSpacing="2">
                                                            <ui:CsText Text="{Binding OutputPriceText}"
                                                                       FontWeight="SemiBold"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                            <ui:CsText Grid.Row="1"
                                                                       Text="{Binding OutputTierText}"
                                                                       Classes="muted"
                                                                       FontSize="11"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                        </Grid>
                                                    </ui:CsPriceChip>
                                                </ui:CsTableCell>

                                                <ui:CsTableCell Grid.Column="6">
                                                    <ui:CsPriceChip>
                                                        <Grid RowDefinitions="Auto,Auto" RowSpacing="2">
                                                            <ui:CsText Text="{Binding FastMultiplierText}"
                                                                       FontWeight="SemiBold"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                            <ui:CsText Grid.Row="1"
                                                                       Text="{i18n:Tr models.price.multiplier}"
                                                                       Classes="muted"
                                                                       FontSize="11"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                        </Grid>
                                                    </ui:CsPriceChip>
                                                </ui:CsTableCell>

                                                <ui:CsTableCell Grid.Column="7">
                                                    <StackPanel Orientation="Horizontal"
                                                                Spacing="8"
                                                                HorizontalAlignment="Right"
                                                                VerticalAlignment="Center">
                                                        <ui:CsIconButton Command="{Binding #Root.DataContext.EditPricingModelCommand}"
                                                                         CommandParameter="{Binding}"
                                                                         ToolTip.Tip="{i18n:Tr models.edit}">
                                                            <lucide:LucideIcon Kind="Pencil" Size="15" StrokeWidth="2"/>
                                                        </ui:CsIconButton>
                                                        <ui:CsIconButton Classes="danger"
                                                                         Command="{Binding #Root.DataContext.RequestRemovePricingModelCommand}"
                                                                         CommandParameter="{Binding}"
                                                                         ToolTip.Tip="{i18n:Tr models.delete}">
                                                            <lucide:LucideIcon Kind="Trash2" Size="15" StrokeWidth="2"/>
                                                        </ui:CsIconButton>
                                                    </StackPanel>
                                                </ui:CsTableCell>
                                            </Grid>
                                        </ui:CsTableRow>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </ui:CsTable>
                </ScrollViewer>
            </Grid>
        </ui:CsPanel>
    </Grid>
</UserControl>
