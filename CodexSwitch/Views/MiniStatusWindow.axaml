<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CodexSwitch.ViewModels"
        xmlns:ui="using:CodexSwitch.Controls"
        x:Class="CodexSwitch.Views.MiniStatusWindow"
        x:DataType="vm:MainWindowViewModel"
        Height="34"
        MinWidth="170"
        MaxWidth="360"
        SizeToContent="Width"
        CanResize="False"
        ShowInTaskbar="False"
        WindowDecorations="None"
        WindowStartupLocation="Manual"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        TransparencyBackgroundFallback="Transparent"
        Topmost="True"
        PointerEntered="OnPointerEntered"
        PointerExited="OnPointerExited"
        PointerPressed="OnPointerPressed"
        PointerReleased="OnPointerReleased">
    <Border CornerRadius="{StaticResource CsRadiusMd}"
            ClipToBounds="True"
            BorderBrush="{StaticResource CsBorderBrush}"
            BorderThickness="1"
            Background="{StaticResource CsPopoverBrush}"
            Padding="10,5">
        <Grid ColumnDefinitions="24,Auto,Auto"
              Height="22"
              ColumnSpacing="8"
              VerticalAlignment="Center">
                <Border Width="24"
                        Height="24"
                        CornerRadius="{StaticResource CsRadiusSm}"
                        Background="{StaticResource CsMutedBrush}">
                    <ui:CsImageIcon Path="{Binding MiniStatusProviderIconPath}"
                                    Width="20"
                                    Height="20"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"/>
                </Border>
                <ItemsControl Grid.Column="1"
                              ItemsSource="{Binding MiniStatusMetricCards}"
                              VerticalAlignment="Center">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"
                                        Spacing="12"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:MiniStatusMetricCardItem">
                            <StackPanel Orientation="Horizontal"
                                        Spacing="5"
                                        VerticalAlignment="Center">
                                <TextBlock Text="{Binding Label}"
                                           Foreground="{StaticResource CsMutedForegroundBrush}"
                                           FontSize="13"
                                           IsVisible="{Binding ShowsTextLabel}"
                                           VerticalAlignment="Center"/>
                                <ui:CsActivityArrow Glyph="{Binding ArrowGlyph}"
                                                    Direction="{Binding ArrowDirection}"
                                                    IsActive="{Binding IsActive}"
                                                    Foreground="{StaticResource CsMutedForegroundBrush}"
                                                    ActiveForeground="{Binding ArrowActiveForeground}"
                                                    FontSize="13"
                                                    Width="14"
                                                    Height="16"
                                                    IsVisible="{Binding ShowsArrow}"
                                                    VerticalAlignment="Center"/>
                                <ui:CsRollingNumber Value="{Binding NumericValue}"
                                                    UseCompactFormat="{Binding UseCompactValueFormat}"
                                                    Foreground="{StaticResource CsForegroundBrush}"
                                                    FontSize="15"
                                                    FontWeight="SemiBold"
                                                    MinWidth="18"
                                                    MaxWidth="74"
                                                    VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            <StackPanel Orientation="Horizontal"
                        Spacing="10"
                        Grid.Column="2"
                        IsVisible="{Binding MiniStatusHasQuotaRow}"
                        VerticalAlignment="Center">
                <TextBlock Foreground="{StaticResource CsForegroundBrush}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           IsVisible="{Binding MiniStatusHasDailyQuota}">
                    <Run Text="&#x65E5; "/>
                    <Run Text="{Binding MiniStatusDailyQuotaText}"/>
                </TextBlock>
                <TextBlock Foreground="{StaticResource CsForegroundBrush}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           IsVisible="{Binding MiniStatusHasWeeklyQuota}">
                    <Run Text="&#x5468; "/>
                    <Run Text="{Binding MiniStatusWeeklyQuotaText}"/>
                </TextBlock>
                <TextBlock Foreground="{StaticResource CsForegroundBrush}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           IsVisible="{Binding MiniStatusHasPackageQuota}">
                    <Run Text="&#x5305; "/>
                    <Run Text="{Binding MiniStatusPackageQuotaText}"/>
                </TextBlock>
            </StackPanel>
        </Grid>
    </Border>
</Window>
