<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CodexSwitch.ViewModels"
             xmlns:ui="using:CodexSwitch.Controls"
             xmlns:i18n="using:CodexSwitch.I18n"
             xmlns:lucide="using:Lucide.Avalonia"
             x:Class="CodexSwitch.Views.Dialogs.ProviderEditorDialog"
             x:Name="Root"
             x:DataType="vm:MainWindowViewModel">
    <ui:CsDialog IsVisible="{Binding IsProviderDialogOpen}">
        <Border Classes="dialog-card"
                Width="720"
                MaxHeight="600"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <Grid RowDefinitions="Auto,*,Auto" RowSpacing="16">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <StackPanel Spacing="4">
                        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                            <Border Width="34"
                                    Height="34"
                                    CornerRadius="10"
                                    Background="#173B82F6"
                                    BorderBrush="#333B82F6"
                                    BorderThickness="1">
                                <lucide:LucideIcon Kind="Router"
                                                   Size="17"
                                                   StrokeWidth="2"
                                                   Foreground="#60A5FA"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                            </Border>
                            <ui:CsText Text="{Binding ProviderDialogTitle}" Classes="title"/>
                        </StackPanel>
                        <ui:CsText Text="{i18n:Tr providerDialog.description}"
                                   Classes="muted"/>
                    </StackPanel>
                    <ui:CsIconButton Grid.Column="1"
                                     Classes="dialog-close"
                                     Command="{Binding CloseProviderDialogCommand}"
                                     ToolTip.Tip="{i18n:Tr common.close}">
                        <lucide:LucideIcon Kind="X" Size="16" StrokeWidth="2"/>
                    </ui:CsIconButton>
                </Grid>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Spacing="12">
                        <Border Classes="dialog-section"
                                IsVisible="{Binding IsAddingProviderDialog}">
                            <Grid RowDefinitions="Auto,Auto"
                                  RowSpacing="10">
                                <Grid ColumnDefinitions="*,Auto"
                                      ColumnSpacing="12">
                                    <StackPanel Spacing="3">
                                        <ui:CsText Text="{i18n:Tr addProvider.templates}" Classes="heading"/>
                                        <ui:CsText Text="{i18n:Tr addProvider.oauthTemplateHint}"
                                                   Classes="muted"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <ui:CsButton Grid.Column="1"
                                                 Classes="outline compact"
                                                 Command="{Binding LoginCodexOAuthCommand}">
                                        <StackPanel Orientation="Horizontal" Spacing="7">
                                            <lucide:LucideIcon Kind="KeyRound" Size="14" StrokeWidth="2"/>
                                            <TextBlock Text="{i18n:Tr addProvider.codexOAuthLogin}"/>
                                        </StackPanel>
                                    </ui:CsButton>
                                </Grid>

                                <ItemsControl Grid.Row="1"
                                              ItemsSource="{Binding ProviderTemplates}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ProviderTemplateItem">
                                            <ui:CsButton Margin="0,0,8,8"
                                                         Classes="outline compact"
                                                         Classes.active="{Binding IsSelected}"
                                                         Command="{Binding SelectCommand}"
                                                         CommandParameter="{Binding}"
                                                         ToolTip.Tip="{Binding Description}">
                                                <StackPanel Orientation="Horizontal" Spacing="7">
                                                    <ui:CsImageIcon Path="{Binding IconPath}" Width="16" Height="16"/>
                                                    <TextBlock Text="{Binding DisplayName}"/>
                                                </StackPanel>
                                            </ui:CsButton>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Border>

                        <Border Classes="dialog-section">
                            <Grid RowDefinitions="Auto,Auto,Auto,Auto"
                                  ColumnDefinitions="*,*"
                                  ColumnSpacing="12"
                                  RowSpacing="12">
                                <ui:CsText Text="{i18n:Tr providerDialog.connection}" Classes="heading"/>
                                <ui:CsField Grid.Row="1" Label="{i18n:Tr addProvider.providerName}">
                                    <ui:CsInput Text="{Binding SelectedProviderName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </ui:CsField>
                                <ui:CsField Grid.Row="1" Grid.Column="1" Label="{i18n:Tr providerDialog.defaultModel}">
                                    <ui:CsInput Text="{Binding SelectedDefaultModel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </ui:CsField>
                                <ui:CsField Grid.Row="2" Label="{i18n:Tr addProvider.note}">
                                    <ui:CsInput Text="{Binding SelectedProviderNote, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </ui:CsField>
                                <ui:CsField Grid.Row="2" Grid.Column="1" Label="{i18n:Tr addProvider.website}">
                                    <ui:CsInput Text="{Binding SelectedProviderWebsite, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                PlaceholderText="{i18n:Tr addProvider.websitePlaceholder}"/>
                                </ui:CsField>
                                <ui:CsField Grid.Row="3" Label="{i18n:Tr addProvider.baseUrl}">
                                    <ui:CsInput Text="{Binding SelectedBaseUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                PlaceholderText="https://your-api-endpoint.com/v1"/>
                                </ui:CsField>
                                <ui:CsField Grid.Row="3" Grid.Column="1" Label="{i18n:Tr providerDialog.apiKey}">
                                    <ui:CsInput Text="{Binding SelectedApiKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                PasswordChar="*"
                                                PlaceholderText="{i18n:Tr addProvider.apiKeyPlaceholder}"/>
                                </ui:CsField>
                            </Grid>
                        </Border>

                        <Border Classes="dialog-section">
                            <Grid RowDefinitions="Auto,Auto,Auto"
                                  ColumnDefinitions="*,*"
                                  ColumnSpacing="12"
                                  RowSpacing="12">
                                <ui:CsText Text="{i18n:Tr providerDialog.protocolRouting}" Classes="heading"/>
                                <ui:CsField Grid.Row="1" Label="{i18n:Tr providerDialog.protocol}">
                                    <ui:CsSelect ItemsSource="{Binding ProtocolOptions}"
                                                 SelectedItem="{Binding SelectedProtocol, Mode=TwoWay}"/>
                                </ui:CsField>
                                <ui:CsField Grid.Row="1" Grid.Column="1" Label="{i18n:Tr providerDialog.serviceTier}">
                                    <ui:CsInput Text="{Binding SelectedServiceTier, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="{i18n:Tr providerDialog.serviceTierPlaceholder}"/>
                                </ui:CsField>

                                <WrapPanel Grid.Row="2"
                                           Grid.ColumnSpan="2">
                                    <ui:CsSwitch Content="{i18n:Tr providerDialog.enabled}"
                                                 Margin="0,0,22,8"
                                                 IsChecked="{Binding SelectedProviderEnabled, Mode=TwoWay}"/>
                                    <ui:CsSwitch Content="{i18n:Tr providerDialog.supportsCodex}"
                                                 Margin="0,0,22,8"
                                                 IsChecked="{Binding SelectedSupportsCodex, Mode=TwoWay}"/>
                                    <ui:CsSwitch Content="{i18n:Tr providerDialog.supportsClaudeCode}"
                                                 Margin="0,0,22,8"
                                                 IsChecked="{Binding SelectedSupportsClaudeCode, Mode=TwoWay}"/>
                                    <ui:CsSwitch Content="{i18n:Tr providerDialog.supportsWebSockets}"
                                                 Margin="0,0,22,8"
                                                 IsChecked="{Binding SelectedSupportsWebSockets, Mode=TwoWay}"/>
                                    <ui:CsSwitch Content="{i18n:Tr providerDialog.codexOneMillionContext}"
                                                 Margin="0,0,22,8"
                                                 IsChecked="{Binding SelectedCodexOneMillionContextEnabled, Mode=TwoWay}"
                                                 IsEnabled="{Binding IsSelectedCodexOneMillionContextAvailable}"/>
                                    <ui:CsSwitch Content="{i18n:Tr providerDialog.overrideRequestModel}"
                                                 Margin="0,0,22,8"
                                                 IsChecked="{Binding SelectedOverrideModel, Mode=TwoWay}"/>
                                    <ui:CsSwitch Content="{i18n:Tr providerDialog.fastModePricing}"
                                                 Margin="0,0,22,8"
                                                 IsChecked="{Binding SelectedFastMode, Mode=TwoWay}"/>
                                </WrapPanel>
                            </Grid>
                        </Border>

                        <Border Classes="dialog-section">
                            <StackPanel Spacing="12">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Spacing="3">
                                        <ui:CsText Text="{i18n:Tr usageQuery.title}" Classes="heading"/>
                                        <ui:CsText Text="{i18n:Tr usageQuery.description}"
                                                   Classes="muted"/>
                                    </StackPanel>
                                    <ui:CsSwitch Grid.Column="1"
                                                 Content="{i18n:Tr usageQuery.enabled}"
                                                 IsChecked="{Binding SelectedUsageQueryEnabled, Mode=TwoWay}"
                                                 VerticalAlignment="Center"/>
                                </Grid>

                                <Border Classes="usage-query-details"
                                        Classes.expanded="{Binding SelectedUsageQueryEnabled}"
                                        IsHitTestVisible="{Binding SelectedUsageQueryEnabled}">
                                    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                                          ColumnDefinitions="*,*"
                                          ColumnSpacing="12"
                                          RowSpacing="12">
                                        <StackPanel Grid.ColumnSpan="2" Spacing="8">
                                            <ui:CsText Text="{i18n:Tr usageQuery.template}" Classes="muted"/>
                                            <ItemsControl ItemsSource="{Binding UsageQueryTemplates}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:UsageQueryTemplateItem">
                                                        <ui:CsButton Margin="0,0,8,8"
                                                                     Classes="outline compact"
                                                                     Classes.active="{Binding IsSelected}"
                                                                     Command="{Binding SelectCommand}"
                                                                     CommandParameter="{Binding}">
                                                            <StackPanel Orientation="Horizontal" Spacing="7">
                                                                <lucide:LucideIcon Kind="Activity" Size="14" StrokeWidth="2"/>
                                                                <TextBlock Text="{Binding DisplayName}"/>
                                                            </StackPanel>
                                                        </ui:CsButton>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>

                                        <ui:CsField Grid.Row="1" Label="{i18n:Tr usageQuery.method}">
                                            <ui:CsSelect ItemsSource="{Binding UsageQueryMethods}"
                                                         SelectedItem="{Binding SelectedUsageQueryMethod, Mode=TwoWay}"/>
                                        </ui:CsField>
                                        <ui:CsField Grid.Row="1" Grid.Column="1" Label="{i18n:Tr usageQuery.timeout}">
                                            <ui:CsInput Text="{Binding SelectedUsageQueryTimeoutSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        </ui:CsField>
                                        <ui:CsField Grid.Row="2" Grid.ColumnSpan="2" Label="{i18n:Tr usageQuery.url}">
                                            <ui:CsInput Text="{Binding SelectedUsageQueryUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                        PlaceholderText="origin/api/usage/token"/>
                                        </ui:CsField>
                                        <ui:CsField Grid.Row="3" Label="{i18n:Tr usageQuery.headers}">
                                            <ui:CsTextarea Text="{Binding SelectedUsageQueryHeaders, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                           MinHeight="72"
                                                           PlaceholderText="Authorization: Bearer apiKey"/>
                                        </ui:CsField>
                                        <ui:CsField Grid.Row="3" Grid.Column="1" Label="{i18n:Tr usageQuery.body}">
                                            <ui:CsTextarea Text="{Binding SelectedUsageQueryBody, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                           MinHeight="72"
                                                           PlaceholderText="optional JSON"/>
                                        </ui:CsField>

                                        <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Spacing="12">
                                            <Grid ColumnDefinitions="*,*,*"
                                                  RowDefinitions="Auto,Auto,Auto,Auto"
                                                  ColumnSpacing="10"
                                                  RowSpacing="10">
                                                <ui:CsField Label="{i18n:Tr usageQuery.remainingPath}">
                                                    <ui:CsInput Text="{Binding SelectedUsageQueryRemainingPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="data.total_available"/>
                                                </ui:CsField>
                                                <ui:CsField Grid.Column="1" Label="{i18n:Tr usageQuery.unit}">
                                                    <ui:CsInput Text="{Binding SelectedUsageQueryUnit, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="tokens"/>
                                                </ui:CsField>
                                                <ui:CsField Grid.Column="2" Label="{i18n:Tr usageQuery.unitPath}">
                                                    <ui:CsInput Text="{Binding SelectedUsageQueryUnitPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                </ui:CsField>

                                                <ui:CsField Grid.Row="1" Label="{i18n:Tr usageQuery.usedPath}">
                                                    <ui:CsInput Text="{Binding SelectedUsageQueryUsedPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="data.total_used"/>
                                                </ui:CsField>
                                                <ui:CsField Grid.Row="1" Grid.Column="1" Label="{i18n:Tr usageQuery.totalPath}">
                                                    <ui:CsInput Text="{Binding SelectedUsageQueryTotalPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="data.total_granted"/>
                                                </ui:CsField>
                                                <ui:CsField Grid.Row="1" Grid.Column="2" Label="{i18n:Tr usageQuery.unlimitedPath}">
                                                    <ui:CsInput Text="{Binding SelectedUsageQueryUnlimitedPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="data.unlimited_quota"/>
                                                </ui:CsField>

                                                <ui:CsField Grid.Row="2" Label="{i18n:Tr usageQuery.successPath}">
                                                    <ui:CsInput Text="{Binding SelectedUsageQuerySuccessPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                </ui:CsField>
                                                <ui:CsField Grid.Row="2" Grid.Column="1" Label="{i18n:Tr usageQuery.errorPath}">
                                                    <ui:CsInput Text="{Binding SelectedUsageQueryErrorPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="error"/>
                                                </ui:CsField>
                                                <ui:CsField Grid.Row="2" Grid.Column="2" Label="{i18n:Tr usageQuery.errorMessagePath}">
                                                    <ui:CsInput Text="{Binding SelectedUsageQueryErrorMessagePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="message"/>
                                                </ui:CsField>

                                                <ui:CsField Grid.Row="3" Label="{i18n:Tr usageQuery.planPath}">
                                                    <ui:CsInput Text="{Binding SelectedUsageQueryPlanNamePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                </ui:CsField>
                                                <ui:CsField Grid.Row="3" Grid.Column="1" Label="{i18n:Tr usageQuery.dailyResetPath}">
                                                    <ui:CsInput Text="{Binding SelectedUsageQueryDailyResetPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                </ui:CsField>
                                                <ui:CsField Grid.Row="3" Grid.Column="2" Label="{i18n:Tr usageQuery.weeklyResetPath}">
                                                    <ui:CsInput Text="{Binding SelectedUsageQueryWeeklyResetPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                </ui:CsField>
                                            </Grid>

                                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                                <ui:CsButton Classes="outline compact"
                                                             Command="{Binding TestProviderUsageQueryCommand}">
                                                    <StackPanel Orientation="Horizontal" Spacing="7">
                                                        <lucide:LucideIcon Kind="Play" Size="14" StrokeWidth="2"/>
                                                        <TextBlock Text="{i18n:Tr usageQuery.test}"/>
                                                    </StackPanel>
                                                </ui:CsButton>
                                                <ui:CsText Grid.Column="1"
                                                           Text="{Binding UsageQueryTestResult}"
                                                           Classes="muted"
                                                           TextWrapping="Wrap"
                                                           VerticalAlignment="Center"/>
                                            </Grid>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Classes="dialog-section">
                            <Grid RowDefinitions="Auto,Auto"
                                  RowSpacing="12">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Spacing="3">
                                        <ui:CsText Text="{i18n:Tr providerDialog.modelRoutes}" Classes="heading"/>
                                        <ui:CsText Text="{i18n:Tr providerDialog.routesDescription}"
                                                   Classes="muted"/>
                                    </StackPanel>
                                    <ui:CsButton Grid.Column="1"
                                                 Classes="outline compact"
                                                 Command="{Binding AddProviderModelCommand}">
                                        <StackPanel Orientation="Horizontal" Spacing="7">
                                            <lucide:LucideIcon Kind="Plus" Size="14" StrokeWidth="2"/>
                                            <TextBlock Text="{i18n:Tr providerDialog.addRoute}"/>
                                        </StackPanel>
                                    </ui:CsButton>
                                </Grid>

                                <ItemsControl Grid.Row="1" ItemsSource="{Binding ModelRows}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ModelEditorItem">
                                            <Border Classes="route-row" Margin="0,0,0,10">
                                                <Grid RowDefinitions="Auto,Auto"
                                                      ColumnDefinitions="1.1*,1.1*,1.1*,Auto"
                                                      ColumnSpacing="10"
                                                      RowSpacing="10">
                                                    <ui:CsField Label="{i18n:Tr providerDialog.modelId}">
                                                        <ui:CsInput Text="{Binding Id, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                    </ui:CsField>
                                                    <ui:CsField Grid.Column="1" Label="{i18n:Tr providerDialog.upstreamModel}">
                                                        <ui:CsInput Text="{Binding UpstreamModel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                    </ui:CsField>
                                                    <ui:CsField Grid.Column="2" Label="{i18n:Tr providerDialog.protocol}">
                                                        <ui:CsSelect ItemsSource="{Binding ProtocolOptions}"
                                                                     SelectedItem="{Binding Protocol, Mode=TwoWay}"/>
                                                    </ui:CsField>
                                                    <ui:CsIconButton Grid.Column="3"
                                                                     Classes="danger"
                                                                     Command="{Binding #Root.DataContext.RemoveProviderModelCommand}"
                                                                     CommandParameter="{Binding}"
                                                                     VerticalAlignment="Bottom"
                                                                     ToolTip.Tip="{i18n:Tr providerDialog.removeRoute}">
                                                        <lucide:LucideIcon Kind="Trash2" Size="15" StrokeWidth="2"/>
                                                    </ui:CsIconButton>

                                                    <ui:CsField Grid.Row="1" Label="{i18n:Tr providerDialog.displayName}">
                                                        <ui:CsInput Text="{Binding DisplayName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                    </ui:CsField>
                                                    <ui:CsField Grid.Row="1" Grid.Column="1" Label="{i18n:Tr providerDialog.serviceTier}">
                                                        <ui:CsInput Text="{Binding ServiceTier, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="{i18n:Tr providerDialog.serviceTierPlaceholder}"/>
                                                    </ui:CsField>
                                                    <ui:CsSwitch Grid.Row="1"
                                                                 Grid.Column="2"
                                                                 Content="{i18n:Tr providerDialog.fastMode}"
                                                                 IsChecked="{Binding FastMode, Mode=TwoWay}"
                                                                 VerticalAlignment="Bottom"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Border>

                        <Border Classes="dialog-section">
                            <Grid RowDefinitions="Auto,Auto"
                                  RowSpacing="12">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Spacing="3">
                                        <ui:CsText Text="{i18n:Tr providerDialog.modelConversions}" Classes="heading"/>
                                        <ui:CsText Text="{i18n:Tr providerDialog.conversionsDescription}"
                                                   Classes="muted"/>
                                    </StackPanel>
                                    <ui:CsButton Grid.Column="1"
                                                 Classes="outline compact"
                                                 Command="{Binding AddModelConversionCommand}">
                                        <StackPanel Orientation="Horizontal" Spacing="7">
                                            <lucide:LucideIcon Kind="Plus" Size="14" StrokeWidth="2"/>
                                            <TextBlock Text="{i18n:Tr providerDialog.addConversion}"/>
                                        </StackPanel>
                                    </ui:CsButton>
                                </Grid>

                                <ItemsControl Grid.Row="1" ItemsSource="{Binding ModelConversionRows}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ModelConversionEditorItem">
                                            <Border Classes="route-row" Margin="0,0,0,10">
                                                <Grid RowDefinitions="Auto,Auto"
                                                      ColumnDefinitions="1.2*,1.2*,Auto"
                                                      ColumnSpacing="10"
                                                      RowSpacing="10">
                                                    <ui:CsField Label="{i18n:Tr providerDialog.conversionSourceModel}">
                                                        <ui:CsInput Text="{Binding SourceModel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                    IsReadOnly="{Binding IsDefault}"/>
                                                    </ui:CsField>
                                                    <ui:CsField Grid.Column="1" Label="{i18n:Tr providerDialog.conversionTargetModel}">
                                                        <ui:CsInput Text="{Binding TargetModel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                    IsEnabled="{Binding CanEditTarget}"
                                                                    PlaceholderText="{i18n:Tr providerDialog.conversionDefaultTarget}"/>
                                                    </ui:CsField>
                                                    <ui:CsIconButton Grid.Column="2"
                                                                     Classes="danger"
                                                                     Command="{Binding #Root.DataContext.RemoveModelConversionCommand}"
                                                                     CommandParameter="{Binding}"
                                                                     IsEnabled="{Binding CanRemove}"
                                                                     VerticalAlignment="Bottom"
                                                                     ToolTip.Tip="{i18n:Tr providerDialog.removeConversion}">
                                                        <lucide:LucideIcon Kind="Trash2" Size="15" StrokeWidth="2"/>
                                                    </ui:CsIconButton>

                                                    <ui:CsSwitch Grid.Row="1"
                                                                 Content="{i18n:Tr providerDialog.conversionUseDefaultModel}"
                                                                 IsChecked="{Binding UseDefaultModel, Mode=TwoWay}"
                                                                 IsEnabled="{Binding CanEditUseDefaultModel}"/>
                                                    <ui:CsSwitch Grid.Row="1"
                                                                 Grid.Column="1"
                                                                 Content="{i18n:Tr providerDialog.conversionEnabled}"
                                                                 IsChecked="{Binding Enabled, Mode=TwoWay}"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <Grid Grid.Row="2" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                    <ui:CsText Text="{i18n:Tr providerDialog.footer}"
                               Classes="muted"
                               VerticalAlignment="Center"/>
                    <ui:CsButton Grid.Column="1"
                                 Classes="outline compact"
                                 Command="{Binding CloseProviderDialogCommand}"
                                 Content="{i18n:Tr common.cancel}"/>
                    <ui:CsButton Grid.Column="2"
                                 Classes="compact"
                                 Command="{Binding SaveProviderCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="7">
                            <lucide:LucideIcon Kind="Save" Size="14" StrokeWidth="2"/>
                            <TextBlock Text="{i18n:Tr providerDialog.save}"/>
                        </StackPanel>
                    </ui:CsButton>
                </Grid>
            </Grid>
        </Border>
    </ui:CsDialog>
</UserControl>
