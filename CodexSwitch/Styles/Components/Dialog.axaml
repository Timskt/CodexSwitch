<Styles xmlns="https://github.com/avaloniaui"
        xmlns:ui="using:CodexSwitch.Controls">
    <Style Selector="ui|CsDialog">
        <Setter Property="Opacity" Value="1"/>
        <Setter Property="Transitions">
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.16"/>
            </Transitions>
        </Setter>
        <Setter Property="Template">
            <ControlTemplate>
                <Grid Background="#CC000000">
                    <ContentPresenter Margin="24"
                                      Content="{TemplateBinding Content}"/>
                </Grid>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="Border.dialog-card">
        <Setter Property="Background" Value="{StaticResource CsCardBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource CsBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource CsRadiusXl}"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="BoxShadow" Value="0 24 64 0 #A6000000"/>
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.14"/>
                <BrushTransition Property="BorderBrush" Duration="0:0:0.14"/>
                <DoubleTransition Property="Opacity" Duration="0:0:0.14"/>
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Border.dialog-card:pointerover">
        <Setter Property="BorderBrush" Value="{StaticResource CsBorderBrush}"/>
    </Style>
    <Style Selector="Border.dialog-card.model-editor-card">
        <Setter Property="Width" Value="640"/>
        <Setter Property="MaxWidth" Value="720"/>
        <Setter Property="MaxHeight" Value="620"/>
        <Setter Property="Padding" Value="0"/>
    </Style>

    <Style Selector="Border.dialog-header">
        <Setter Property="Padding" Value="22,20,18,16"/>
        <Setter Property="BorderBrush" Value="{StaticResource CsBorderBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
    </Style>
    <Style Selector="StackPanel.dialog-body-stack">
        <Setter Property="Margin" Value="20,16"/>
        <Setter Property="Spacing" Value="12"/>
    </Style>
    <Style Selector="Border.dialog-footer">
        <Setter Property="Padding" Value="16,16,20,20"/>
        <Setter Property="Background" Value="#08FFFFFF"/>
        <Setter Property="BorderBrush" Value="{StaticResource CsBorderBrush}"/>
        <Setter Property="BorderThickness" Value="0,1,0,0"/>
    </Style>
    <Style Selector="ui|CsIconButton.dialog-close">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
    </Style>
    <Style Selector="ui|CsIconButton.dialog-close:pointerover">
        <Setter Property="Background" Value="{StaticResource CsAccentBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource CsBorderBrush}"/>
    </Style>

    <Style Selector="Border.dialog-section">
        <Setter Property="Background" Value="#08FFFFFF"/>
        <Setter Property="BorderBrush" Value="{StaticResource CsBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource CsRadiusXl}"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.14"/>
                <BrushTransition Property="BorderBrush" Duration="0:0:0.14"/>
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Border.dialog-section:pointerover">
        <Setter Property="Background" Value="#0FFFFFFF"/>
        <Setter Property="BorderBrush" Value="{StaticResource CsBorderBrush}"/>
    </Style>
    <Style Selector="Border.dialog-note">
        <Setter Property="Background" Value="#0FFFFFFF"/>
        <Setter Property="BorderBrush" Value="{StaticResource CsBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource CsRadiusMd}"/>
        <Setter Property="Padding" Value="10"/>
    </Style>

    <Style Selector="Border.usage-query-details">
        <Setter Property="ClipToBounds" Value="True"/>
        <Setter Property="Opacity" Value="0"/>
        <Setter Property="MaxHeight" Value="0"/>
        <Setter Property="Margin" Value="0,-4,0,0"/>
        <Setter Property="Transitions">
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.16"/>
                <DoubleTransition Property="MaxHeight" Duration="0:0:0.22"/>
                <ThicknessTransition Property="Margin" Duration="0:0:0.18"/>
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Border.usage-query-details.expanded">
        <Setter Property="Opacity" Value="1"/>
        <Setter Property="MaxHeight" Value="920"/>
        <Setter Property="Margin" Value="0,0,0,0"/>
    </Style>

    <Style Selector="Border.route-row">
        <Setter Property="Background" Value="#08FFFFFF"/>
        <Setter Property="BorderBrush" Value="{StaticResource CsBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource CsRadiusLg}"/>
        <Setter Property="Padding" Value="12"/>
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.14"/>
                <BrushTransition Property="BorderBrush" Duration="0:0:0.14"/>
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Border.route-row:pointerover">
        <Setter Property="Background" Value="#0FFFFFFF"/>
        <Setter Property="BorderBrush" Value="{StaticResource CsHoverBorderBrush}"/>
    </Style>
</Styles>
