<Styles xmlns="https://github.com/avaloniaui"
        xmlns:ui="using:CodexSwitch.Controls">
    <Style Selector="ui|CsProviderContextMenu">
        <Setter Property="MinWidth" Value="208"/>
        <Setter Property="Padding" Value="6"/>
        <Setter Property="Background" Value="{StaticResource CsPopoverBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource CsPopoverForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource CsBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Transitions">
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.14"/>
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="MenuItem.provider-menu-item">
        <Setter Property="MinHeight" Value="44"/>
        <Setter Property="Padding" Value="8,7"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="{StaticResource CsForegroundBrush}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.10"/>
                <BrushTransition Property="Foreground" Duration="0:0:0.10"/>
                <DoubleTransition Property="Opacity" Duration="0:0:0.10"/>
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="MenuItem.provider-menu-item:pointerover">
        <Setter Property="Background" Value="#33404040"/>
        <Setter Property="Foreground" Value="{StaticResource CsAccentForegroundBrush}"/>
    </Style>
    <Style Selector="MenuItem.provider-menu-item.active-route">
        <Setter Property="Foreground" Value="{StaticResource CsForegroundBrush}"/>
    </Style>
    <Style Selector="MenuItem.provider-menu-item.selected">
        <Setter Property="Background" Value="#2EFFFFFF"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
    <Style Selector="MenuItem.provider-menu-item.danger TextBlock.provider-menu-name">
        <Setter Property="Foreground" Value="{StaticResource CsDestructiveBrush}"/>
    </Style>
    <Style Selector="MenuItem.provider-menu-item.danger:pointerover">
        <Setter Property="Background" Value="#2A7F1D1D"/>
    </Style>
    <Style Selector="MenuItem.provider-menu-caption">
        <Setter Property="MinHeight" Value="26"/>
        <Setter Property="Padding" Value="9,5"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="{StaticResource CsMutedForegroundBrush}"/>
        <Setter Property="IsHitTestVisible" Value="False"/>
    </Style>
    <Style Selector="Separator.provider-menu-separator">
        <Setter Property="Margin" Value="6,4"/>
        <Setter Property="Background" Value="{StaticResource CsBorderBrush}"/>
    </Style>

    <Style Selector="Border.provider-menu-indicator">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="{StaticResource CsBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>
    <Style Selector="Border.provider-menu-indicator.active-route">
        <Setter Property="BorderBrush" Value="{StaticResource CsSuccessBrush}"/>
    </Style>
    <Style Selector="Border.provider-menu-indicator.selected">
        <Setter Property="Background" Value="{StaticResource CsPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource CsPrimaryBrush}"/>
    </Style>
    <Style Selector="Border.provider-menu-state">
        <Setter Property="Padding" Value="6,2"/>
        <Setter Property="CornerRadius" Value="999"/>
        <Setter Property="Background" Value="{StaticResource CsSecondaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource CsBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>
    <Style Selector="Border.provider-menu-state.selected">
        <Setter Property="Background" Value="#33404040"/>
        <Setter Property="BorderBrush" Value="{StaticResource CsBorderBrush}"/>
    </Style>
    <Style Selector="Border.provider-menu-state.active-route">
        <Setter Property="Background" Value="#263B2E"/>
        <Setter Property="BorderBrush" Value="#2F6843"/>
    </Style>
    <Style Selector="TextBlock.provider-menu-name">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource CsForegroundBrush}"/>
    </Style>
    <Style Selector="TextBlock.provider-menu-meta">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Foreground" Value="{StaticResource CsMutedForegroundBrush}"/>
    </Style>
    <Style Selector="Border.provider-menu-state TextBlock">
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource CsMutedForegroundBrush}"/>
    </Style>
    <Style Selector="Border.provider-menu-state.active-route TextBlock">
        <Setter Property="Foreground" Value="{StaticResource CsSuccessBrush}"/>
    </Style>
</Styles>
